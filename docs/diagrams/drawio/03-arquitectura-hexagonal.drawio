          <mxGeometry x="30" y="35" width="180" height="40"/>
        </mxCell>
        <mxCell id="ports-out" value="📤 UserRepository&lt;br&gt;&lt;font style='font-size:9px'&gt;Puerto de salida&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#78350F;strokeColor=#F59E0B;fontColor=#FDE047;fontSize=10;" vertex="1" parent="domain-layer">
          <mxGeometry x="30" y="90" width="180" height="40"/>
        </mxCell>
        <mxCell id="auth-svc" value="⚙️ AuthService&lt;br&gt;&lt;font style='font-size:9px'&gt;Caso de uso puro&lt;br&gt;register() verify() login()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B45309;strokeColor=#F59E0B;fontColor=#FFFFFF;fontSize=11;" vertex="1" parent="domain-layer">
          <mxGeometry x="250" y="35" width="190" height="95"/>
        </mxCell>
        <mxCell id="models" value="📦 Modelos&lt;br&gt;&lt;font style='font-size:9px'&gt;User (POJO)&lt;br&gt;OtpCode (POJO)&lt;br&gt;RefreshToken (POJO)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#78350F;strokeColor=#F59E0B;fontColor=#FDE047;fontSize=10;" vertex="1" parent="domain-layer">
          <mxGeometry x="480" y="35" width="180" height="95"/>
