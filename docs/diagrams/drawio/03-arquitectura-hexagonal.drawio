<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="Hexagonal - Auth" id="hexagonal">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <mxCell id="title" value="&lt;b&gt;ARQUITECTURA HEXAGONAL — Servicio de Identidad (Auth)&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontColor=#4C1D95;" vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="600" height="30"/>
        </mxCell>

        <!-- Layer 1: Input Adapters -->
        <mxCell id="input-layer" value="&lt;b&gt;ADAPTADORES DE ENTRADA (INPUT)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0C4A6E33;strokeColor=#0EA5E9;strokeColor=#0EA5E9;fontColor=#38BDF8;fontSize=13;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="70" width="700" height="100"/>
        </mxCell>
        <mxCell id="rest" value="🌐 AuthController&lt;br&gt;&lt;font style='font-size:9px'&gt;REST endpoints&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0C4A6E;strokeColor=#0EA5E9;fontColor=#FFFFFF;fontSize=11;" vertex="1" parent="input-layer">
          <mxGeometry x="40" y="35" width="170" height="50"/>
        </mxCell>
        <mxCell id="security" value="🔒 JwtAuthFilter&lt;br&gt;&lt;font style='font-size:9px'&gt;Seguridad&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0C4A6E;strokeColor=#0EA5E9;fontColor=#FFFFFF;fontSize=11;" vertex="1" parent="input-layer">
          <mxGeometry x="260" y="35" width="170" height="50"/>
        </mxCell>
        <mxCell id="exc" value="⚠️ GlobalExceptionHandler&lt;br&gt;&lt;font style='font-size:9px'&gt;Manejo errores&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0C4A6E;strokeColor=#0EA5E9;fontColor=#FFFFFF;fontSize=11;" vertex="1" parent="input-layer">
          <mxGeometry x="480" y="35" width="170" height="50"/>
        </mxCell>

        <!-- Layer 2: Domain Core -->
        <mxCell id="domain-layer" value="&lt;b&gt;🧠 DOMINIO (Core — CERO dependencias externas)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F59E0B15;strokeColor=#F59E0B;fontColor=#F59E0B;fontSize=13;strokeWidth=2;" vertex="1" parent="1">
