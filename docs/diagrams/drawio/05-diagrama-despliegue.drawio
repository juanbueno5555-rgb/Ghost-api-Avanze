        <mxCell id="dev-box" value="&lt;b&gt;🖥️ DEV — Local&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E3A5F33;strokeColor=#2563EB;fontColor=#60A5FA;fontSize=14;" vertex="1" parent="1">
